  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "3"
  AssertionAction "1"
  InitializationCommands "switched_sim_mode = 0;\npebb_bipolarsource = 0;\n\n%"
" Initial Conditions\nv_high0 = 4160\nv_low0 = 700\nbatt_soc0 = 95\nuc_energy0"
" = 85 % min 74% = 1000V\n\n% Model Params\nC_high = 3e-3\nC_low = 1e-3\n\nP_b"
"ase = 1.5E6\nv_highbase = 4160\ni_highbase = P_base/v_highbase/sqrt(3)\nZ_hig"
"hbase = v_highbase^2/P_base;\n\nv_lowbase = 3.3*12*22 %871\ni_lowbase = P_bas"
"e/v_lowbase\n\n% Branch Resistance\nX_over_R = 15;\nX_l = 8*0.008*4.5/1.0;\nR"
"_s = X_l/10\nR_p = X_over_R*X_l;\n\n% Source (PU)\nS_base = 4.5e6\nv_base = 4"
"160\ni_base = S_base/v_base/sqrt(3)\nZ_base = v_base^2/S_base\nw_base = 2*pi*"
"60\n\n% LV Load 0\nP_load0 = 1005e3\nf_load0 = 0.1\nd_load0 = 0.5\ndelay0 = 1"
".0"
