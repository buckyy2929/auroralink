"else\n"
"std = [fs*env(1)/3; fs*env(2)/3; fs*env(3)/3];\n"
"end\n"
"\n"
"if length(mean) < 3\n"
"mean = [mean; mean; mean];\n"
"end\n"
"\n"
"if length(seed) < 3\n"
"seed = [seed; seed; seed];\n"
"end\n"
"\n"
"tau = R*C\n"
"if tau == 0 || ~en_rc\n"
"w = 1\n"
"else\n"
"w = 1/tau\n"
"end"
